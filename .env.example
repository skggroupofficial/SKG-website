# ============================================================
# Shri Kuber Group — environment variables
# Copy to .env.local and fill in. None are required for the
# site to build; the enquiry form falls back to console logging
# when RESEND_API_KEY is absent.
# ============================================================

# Resend API key for the /api/enquire contact form.
# Without it, submissions are logged to the server console instead of emailed.
# Get one at https://resend.com
RESEND_API_KEY=

# Where enquiries are delivered. Defaults to info@shrikubergroup.com.
ENQUIRY_TO=info@shrikubergroup.com

# From address for enquiry emails (optional).
# Must be a verified Resend sender/domain. Defaults to the Resend onboarding sender.
ENQUIRY_FROM=SKG Website <onboarding@resend.dev>
